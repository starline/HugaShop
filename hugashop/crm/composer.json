{
  "name": "hugashop/crm",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "keywords": [
    "ecommerce",
    "crm"
  ],
  "authors": [
    {
      "name": "Andrii Huga"
    }
  ],
  "require": {
    "php": ">=8.1",
    "smarty/smarty": "^5.4",
    "illuminate/database": "^12.18",
    "illuminate/events": "^12.18",
    "symfony/yaml": "^7",
    "jenssegers/agent": "^2.6.4",
    "intervention/image": "^3.11.3",
    "nelexa/zip": "^4.0.2",
    "tecnickcom/tcpdf": "^6.10",
    "facebook/php-business-sdk": "^21.0.3",
    "guzzlehttp/guzzle": "^7.9",
    "openai-php/client": "^0.13",
    "google/recaptcha": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "HugaShop\\Api\\": "Api/",
      "HugaShop\\Extensions\\": "Extensions/",
      "HugaShop\\Modules\\": "Modules/"
    }
  },
  "config": {
    "sort-packages": true
  }
}